---
import Layout from '../layouts/main.astro';
import { DemoGrid } from '@/components/DemoGrid';
import { motion } from 'framer-motion';
---

<Layout>
	<section class="relative py-20 md:py-32 overflow-hidden">
		<!-- Floating background blobs (same as portfolio Hero) -->
		<div class="absolute inset-0 -z-10 pointer-events-none">
			<div class="absolute top-10 -left-8 w-80 h-80 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-[72px] opacity-50 animate-blob-float" style="background-color: #f9a8c9;" />
			<div class="absolute top-10 -right-8 w-80 h-80 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-[72px] opacity-50 animate-blob-float animation-delay-2000" style="background-color: #c4b5fd;" />
			<div class="absolute bottom-0 left-1/3 w-80 h-80 rounded-full mix-blend-multiply dark:mix-blend-soft-light filter blur-[72px] opacity-50 animate-blob-float animation-delay-4000" style="background-color: #ffc59a;" />
		</div>

		<div class="container mx-auto px-4">
			<div class="text-center space-y-4 mb-16">
				<h1 class="text-4xl md:text-6xl font-bold">
					<span class="bg-gradient-to-r from-purple-600 to-pink-600 dark:from-purple-400 dark:to-pink-400 bg-clip-text text-transparent">
						Interactive AI Demos
					</span>
				</h1>
				<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
					Explore our collection of production-ready AI solutions.
					From SEO-optimized content generation to intelligent automation—experience the future of AI-powered tools.
				</p>
			</div>

			<DemoGrid client:load />
		</div>
	</section>
</Layout>
